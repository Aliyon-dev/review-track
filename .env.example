# Vite dev server proxies /api/* to this target
VITE_API_PROXY_TARGET=http://localhost:8000

# Production (Render Web Service): set the same variable in the Render dashboard
# so `npm run start` (vite preview) can proxy /api to your backend.
# Example: VITE_API_PROXY_TARGET=https://review-track-backend.onrender.com

# Alternative: call the API directly from the browser (requires backend CORS).
# Set at build time on Render, then redeploy.
# VITE_API_BASE_URL=https://review-track-backend.onrender.com
